{
  "name": "korean-land-mcp",
  "version": "2.0.0",
  "description": "MCP Server for Korean Land Information System (토지이음 / EUM) - Unified access to land use planning, zoning, urban planning, regulations, and open data for AI assistants",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "setup": "npm install && npm run build && npm run configure",
    "configure": "node scripts/configure.mjs",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "korean-land",
    "토지이음",
    "eum",
    "land-use-planning",
    "urban-planning",
    "zoning",
    "korea",
    "government-data",
    "ai-tools"
  ],
  "author": "UrbanWatcherKr (https://github.com/UrbanWatcherKr)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UrbanWatcherKr/korean-land-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/UrbanWatcherKr/korean-land-mcp/issues"
  },
  "homepage": "https://github.com/UrbanWatcherKr/korean-land-mcp#readme",
  "files": [
    "dist",
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
