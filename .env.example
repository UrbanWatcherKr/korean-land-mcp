# Korean Land MCP Configuration
# === 실제 데이터 연동을 위한 API 키 (선택사항) ===
# vworld.kr (무료 키 발급 추천) → https://vworld.kr
VWORLD_API_KEY=your_vworld_key_here

# data.go.kr 서비스키 (일부 토지 데이터셋)
# DATA_GO_KR_KEY=your_data_gov_key_here

# MCP Server Port (for HTTP mode)
PORT=3000

# Optional: Logging level
LOG_LEVEL=info
